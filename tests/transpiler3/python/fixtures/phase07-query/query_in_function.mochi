fun filter_evens(nums: list<int>): list<int> {
  return from n in nums where n % 2 == 0 select n
}
fun double_all(nums: list<int>): list<int> {
  return from n in nums select n * 2
}
let input = [1, 2, 3, 4, 5, 6]
let evens = filter_evens(input)
let doubled = double_all(evens)
for d in doubled {
  print(d)
}
