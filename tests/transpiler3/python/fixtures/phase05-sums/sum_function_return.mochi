type Result = Ok(value: int) | Err(msg: string)

fun divide(a: int, b: int): Result {
  if b == 0 {
    return Err("division by zero")
  }
  return Ok(a / b)
}

let r1 = divide(10, 2)
let r2 = divide(5, 0)

match r1 {
  Ok(v) => print(v)
  Err(m) => print(m)
}

match r2 {
  Ok(v) => print(v)
  Err(m) => print(m)
}
